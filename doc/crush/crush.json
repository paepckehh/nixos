{
  "$schema": "https://charm.land/crush.json",
  "providers": {
    "ollama": {
      "name": "Ollama",
      "base_url": "http://aiworker02.dbt.corp:11434/v1/",
      "type": "openai",
      "models": [
        {
          "name": "qwen3.6:35b-a3b-coding-mxfp8",
          "id": "qwen3.6:35b-a3b-coding-mxfp8",
          "cost_per_1m_in": 30,
          "cost_per_1m_out": 150,
          "cost_per_1m_in_cached": 3.750,
          "cost_per_1m_out_cached": 0.30,
          "context_window": 256000,
          "default_max_tokens": 64000,
          "can_reason": true,
          "supports_attachments": false
        }
      ]
    }
  },
  "lsp": {
    "go": {
      "command": "/run/current-system/sw/bin/gopls",
      "env": {
        "GOTOOLCHAIN": "go1.26.3"
      }
    },
    "typescript": {
      "command": "/run/current-system/sw/bin/typescript-language-server",
      "args": [
        "--stdio"
      ]
    },
    "nix": {
      "command": "/run/current-system/sw/bin/nil"
    }
  },
  "permissions": {
    "allowed_tools": [
      "view",
      "edit",
      "write",
      "multiedit",
      "ls",
      "grep",
      "jq",
      "bash",
      "python",
      "python3",
      "fetch",
      "agentic_fetch"
    ]
  },
    "options": {
    "disable_metrics": true
  }
}
