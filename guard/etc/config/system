
config system
	option hostname 'REPLACEHOSTNAME'
	option timezone 'CET-1CEST,M3.5.0,M10.5.0/3'
	option zonename 'Europe/Berlin'
	option ttylogin '0'
	option log_size '512'
	option urandom_seed '0'
	option log_ip '10.20.6.100'
	option log_port '514'
	option log_proto 'udp'
	option conloglevel '7'
	option cronloglevel '9'
	option zram_comp_algo 'lz4'
	option clock_hourcycle 'h23'

config timeserver 'ntp'
	list server '== SET NTP SERVER HERE='
	list server 'ALL'

