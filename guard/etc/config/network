config device
	option name 'eth0'
	option ipv6 '0'

config device
	option name 'eth1'
	option ipv6 '0'

config device
	option name 'phy0-sta0'
	option ipv6 '0'

config device
	option name 'phy1-sta0'
	option ipv6 '0'

