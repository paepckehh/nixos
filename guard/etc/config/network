
config interface 'loopback'
	option device 'lo'
	option proto 'static'
	list ipaddr '127.0.0.1/8'

config globals 'globals'
	option dhcp_default_duid '0004c0e23c03c1c341ae926548a3fdc73a32'
	option ula_prefix 'fd6c:8ac5:4ba6::/48'
	option packet_steering '1'

